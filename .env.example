# URL base de Strapi (sin barra final). Obligatoria si quieres apuntar a Strapi local desde el navegador.
# Sin esta variable, las llamadas desde React van al backend público (Railway) y se ven en Network como ese host.
# PUBLIC_STRAPI_URL=http://localhost:1337
# PUBLIC_STRAPI_URL=https://maskottchen-be-production.up.railway.app

# Redes (públicas; se inyectan en el cliente/build). Deben ser URLs absolutas https://...
PUBLIC_FB_URL=
PUBLIC_IG_URL=
