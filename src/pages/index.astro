---
import HeroSlider from "../components/home/HeroSlider.tsx";
import Products from "../components/home/Products.tsx";
import Attributes from "../components/home/Attributes.astro";
import Why from "../components/home/Why.astro";
import Accordion from "../components/home/Accordion.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <HeroSlider client:only="react" />
  <Attributes />
  <Why />

  <ScrollReveal variant="fade-up">
    <Products client:only="react" />
  </ScrollReveal>
  <ScrollReveal variant="fade-up" delay={80}>
    <Accordion />
  </ScrollReveal>
</Layout>
