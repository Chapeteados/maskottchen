---
import Partners from "./Partners";
---

<div
  class="flex min-h-0 w-full flex-col items-center justify-center bg-cover bg-left bg-no-repeat md:h-auto md:flex-1"
  style={`background-image: url(/footer.webp);`}
>
  <div
    class="flex flex-col items-center justify-center bg-[#D9D9D914] rounded-3xl p-8 max-w-6xl mx-auto gap-4 m-32 md:m-0"
  >
    <h1 class="text-2xl font-bold text-white text-center">ENCUENTRA A MASKOTTCHEN CERCA DE TI</h1>
    <p class="text-base text-white text-center">
      Busca el distribuidor más cercano y lleva Maskottchen a casa sin complicaciones.
    </p>
    <div class="flex w-full flex-col items-center justify-center gap-8 md:flex-row">
      <img
        src="/map.webp"
        alt="Map"
        class="w-full max-w-2xl shrink-0 object-contain md:w-3/4 md:max-h-[min(70vh,32rem)]"
      />
      <Partners client:load />
    </div>
  </div>
</div>
