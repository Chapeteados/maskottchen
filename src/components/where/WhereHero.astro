---
import Partners from "./Partners";
import OnlineVendor from "./OnlineVendor.astro";
import { AMAZON_STORE_URL, MERCADO_LIBRE_STORE_URL } from "../../lib/constants";

const vendors = [
  {
    logo: "/amazon.webp",
    alt: "Amazon",
    href: AMAZON_STORE_URL,
  },
  {
    logo: "/ml.webp",
    alt: "Mercado Libre",
    href: MERCADO_LIBRE_STORE_URL,
  },
];
---

<div
  class="flex min-h-0 w-full flex-col items-center justify-center bg-cover bg-top-left bg-no-repeat md:h-auto md:flex-1"
  style={`background-image: url(/footer.webp);`}
>
  <div
    class="m-32 mx-auto flex max-w-6xl flex-col items-center justify-center gap-4 rounded-3xl bg-[#D9D9D914] p-8 md:m-0"
  >
    <h1 class="text-center text-2xl font-bold text-white">ENCUENTRA A MASKOTTCHEN CERCA DE TI</h1>
    <p class="text-center text-base text-white">
      Busca el distribuidor más cercano y lleva Maskottchen a casa sin complicaciones.
    </p>
    <div
      class="grid w-full grid-cols-1 items-start gap-8 md:grid-cols-[2fr_1fr_1fr] md:gap-6 lg:gap-8"
    >
      <img
        src="/map.webp"
        alt="Mapa de puntos de venta Maskottchen en Guadalajara"
        class="w-full min-w-0 object-contain md:max-h-[min(70vh,32rem)]"
      />
      <div class="flex min-h-0 min-w-0 w-full justify-center md:justify-start">
        <Partners client:load />
      </div>
      <aside
        class="flex w-full min-w-0 flex-col items-center justify-center gap-8"
        aria-label="Comprar en línea"
      >
        {
          vendors.map((vendor) => {
            return <OnlineVendor logoSrc={vendor.logo} logoAlt={vendor.alt} href={vendor.href} />;
          })
        }
      </aside>
    </div>
  </div>
</div>
