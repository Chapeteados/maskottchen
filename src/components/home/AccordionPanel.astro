---
import Button from "../Button.astro";
import SocialLinks from "../SocialLinks.astro";

interface Props {
  bg: string;
  panelIndex?: number;
  title?: string;
  variant: "cta" | "contact" | "rrss";
}

const { bg, panelIndex = 0, title = "", variant } = Astro.props;
---

<article
  class:list={[
    "panel group relative flex min-h-[280px] flex-col items-center justify-between overflow-hidden rounded-2xl bg-neutral-300 bg-cover bg-center px-4 py-8 shadow-md md:min-h-0 md:px-6 md:py-10",
  ]}
  style={`background-image: url('${bg}');`}
  data-panel-index={panelIndex}
>
  <div
    class="relative z-10 flex w-full max-w-md flex-1 flex-col items-center justify-center gap-6 text-center"
  >
    {title ? (
      <h2 class="text-balance text-lg font-black uppercase leading-tight text-white filter-[drop-shadow(0_1px_2px_rgba(0,0,0,0.95))_drop-shadow(0_3px_14px_rgba(0,0,0,0.55))] md:text-xl">
        {title}
      </h2>
    ) : null}

    {variant === "cta" ? (
      <Button
        href="/contacto"
        label="¡SÉ PARTE DE MASKOTTCHEN!"
        className="pointer-events-auto text-center font-bold uppercase focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-neutral-900/55 focus-visible:ring-offset-2 focus-visible:ring-offset-white"
      />
    ) : null}

    {variant === "contact" ? (
      <div class="pointer-events-auto max-w-sm rounded-xl border-2 border-[#3B82F6] bg-[#FFED00]/90 px-4 py-3 text-xs font-semibold text-neutral-900 shadow-md md:text-sm">
        <p class="font-bold uppercase">Línea Maskottchen</p>
        <p class="mt-1 flex flex-wrap items-center justify-center gap-x-2 gap-y-1">
          <a
            href="tel:+523311437419"
            class="rounded-sm font-bold underline-offset-2 hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-[#2563EB] focus-visible:ring-offset-2 focus-visible:ring-offset-[#FFED00]"
          >
            33 1143 7419
          </a>
          <span class="text-neutral-600" aria-hidden="true">
            ·
          </span>
          <a
            href="tel:+523477184000"
            class="rounded-sm font-bold underline-offset-2 hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-[#2563EB] focus-visible:ring-offset-2 focus-visible:ring-offset-[#FFED00]"
          >
            347 718 40 00
          </a>
        </p>
        <p class="mt-1 text-[0.7rem] font-normal uppercase md:text-xs">
          Horarios Lun – Vie 9:00 AM – 6:30 PM
        </p>
      </div>
    ) : null}

    {variant === "rrss" ? (
      <ul
        class="pointer-events-auto m-0 flex list-none flex-wrap items-center justify-center gap-5 p-0"
        aria-label="Redes sociales Maskottchen"
      >
        <SocialLinks
          linkClass="inline-flex rounded-full text-white transition hover:opacity-80 focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-neutral-900/60"
          iconClass="h-9 w-9 object-contain brightness-0 invert"
        />
      </ul>
    ) : null}
  </div>
</article>
