---
import Button from "../Button.astro";
import { getYoutubeEmbedUrlFromInput } from "../../lib/youtube";

const { image, youtubeUrl, title, description, buttonLabel, buttonHref } = Astro.props as {
  image?: string;
  youtubeUrl?: string;
  title?: string;
  description?: string;
  buttonLabel?: string;
  buttonHref?: string;
};

const youtubeEmbedSrc = youtubeUrl ? getYoutubeEmbedUrlFromInput(youtubeUrl) : null;
const hasYoutube = Boolean(youtubeEmbedSrc);
const hasMedia = hasYoutube;
---

<div
  class={`relative h-full w-full flex items-center justify-start ${
    !hasMedia ? "bg-cover bg-center" : ""
  }`}
  style={!hasMedia && image ? `background-image: url(${image});` : undefined}
>
  {
    hasYoutube && youtubeEmbedSrc && (
      <iframe
        class="youtube-iframe pointer-events-none absolute inset-0 h-full w-full border-0"
        src="about:blank"
        data-src={youtubeEmbedSrc}
        title="Video de YouTube"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
      />
    )
  }

  {
    !title && !description ? (
      buttonLabel &&
      buttonHref && (
        <Button
          href={buttonHref}
          label={buttonLabel}
          className="z-10 absolute left-1/2 -translate-x-1/2 bottom-24 md:bottom-32"
        />
      )
    ) : (
      <div class="relative z-10 ml-4 md:ml-16 px-4 md:px-6 py-6 md:py-8 rounded-lg max-w-2xl text-center flex flex-col items-center justify-center gap-4">
        <h2 class="text-3xl md:text-5xl font-black text-white">{title}</h2>
        <svg viewBox="0 0 450 150" class="block w-72 h-28 md:w-96 md:h-36">
          <defs>
            <path id="description-arc" d="M 40 200 Q 225 60 410 200" />
          </defs>
          <text class="fill-white text-[72px] md:text-[96px] font-black">
            <textPath href="#description-arc" startOffset="50%" text-anchor="middle">
              {description}
            </textPath>
          </text>
        </svg>
        {buttonLabel && buttonHref && (
          <div class="flex justify-center mt-8">
            <Button href={buttonHref} label={buttonLabel} />
          </div>
        )}
      </div>
    )
  }
</div>
