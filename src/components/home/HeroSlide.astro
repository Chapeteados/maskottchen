---
import Button from "../Button.astro";

const { image, title, description, buttonLabel, buttonHref } = Astro.props as {
    image: string;
    title?: string;
    description?: string;
    buttonLabel?: string;
    buttonHref?: string;
};
---

<div
    class="h-full w-full bg-cover bg-center flex items-center justify-start"
    style={`background-image: url(${image});`}
>
    {
        !title && !description ? (
            buttonLabel &&
            buttonHref && (
                <Button
                    href={buttonHref}
                    label={buttonLabel}
                    className="absolute left-1/2 -translate-x-1/2 bottom-24 md:bottom-32"
                />
            )
        ) : (
            <div class="ml-6 md:ml-16 px-6 py-6 md:py-8 rounded-lg max-w-2xl text-center flex flex-col items-center justify-center">
                <h2 class="text-3xl md:text-5xl font-black text-white">
                    {title}
                </h2>
                <svg
                    viewBox="0 0 450 150"
                    class="block w-72 h-28 md:w-96 md:h-36"
                >
                    <defs>
                        <path
                            id="description-arc"
                            d="M 40 200 Q 225 60 410 200"
                        />
                    </defs>
                    <text class="fill-white text-[72px] md:text-[96px] font-black">
                        <textPath
                            href="#description-arc"
                            startOffset="50%"
                            text-anchor="middle"
                        >
                            {description}
                        </textPath>
                    </text>
                </svg>
                {buttonLabel && buttonHref && (
                    <div class="flex justify-center mt-8">
                        <Button href={buttonHref} label={buttonLabel} />
                    </div>
                )}
            </div>
        )
    }
</div>
