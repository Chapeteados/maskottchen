---
import HeroSlide from "./HeroSlide.astro";
import { getSlides } from "../../lib/strapi";

const slides = await getSlides();
---

<section class="relative h-[100dvh] md:h-[100vh] overflow-hidden" id="hero-slider">
  <div class="relative h-full w-full">
    {
      slides.map((slide, index) => (
        <div
          class={`slider-slide absolute inset-0 transition-opacity duration-700 ease-in-out ${
            index === 0 ? "opacity-100" : "opacity-0"
          }`}
          data-index={index}
          data-duration={slide.durationMs}
        >
          <HeroSlide
            image={slide.image}
            youtubeUrl={slide.youtubeUrl}
            title={slide.title}
            description={slide.description}
            buttonLabel={slide.buttonLabel}
            buttonHref={slide.buttonHref}
          />
        </div>
      ))
    }

    <div
      class="absolute inset-x-0 bottom-8 flex items-center justify-center gap-3"
      aria-label="Controles del slider"
    >
      {
        slides.map((_, index) => (
          <button
            type="button"
            class="slider-dot h-4 w-4 rounded-full border border-white/70 bg-white/80 hover:bg-white transition cursor-pointer"
            aria-label={`Ir al slide ${index + 1}`}
            data-index={index}
          />
        ))
      }
    </div>
  </div>
</section>

<script>
  if (typeof window !== "undefined") {
    const root = document.getElementById("hero-slider");
    if (root) {
      const slideEls = Array.from(
        root.querySelectorAll(".slider-slide") as NodeListOf<HTMLElement>
      );
      const dots = Array.from(root.querySelectorAll(".slider-dot") as NodeListOf<HTMLElement>);

      let current = 0;
      const total = slideEls.length;
      let advanceTimer: ReturnType<typeof setTimeout> | undefined;

      const syncYoutubeEmbeds = () => {
        slideEls.forEach((slide, i) => {
          const iframe = slide.querySelector("iframe.youtube-iframe") as HTMLIFrameElement | null;
          const embedSrc = iframe?.dataset.src;
          if (iframe && embedSrc) {
            if (i === current) {
              if (iframe.src !== embedSrc) {
                iframe.src = embedSrc;
              }
            } else {
              iframe.src = "about:blank";
            }
          }
        });
      };

      const setActive = (index: number) => {
        current = index;
        slideEls.forEach((slide, i) => {
          const isActive = i === current;
          slide.style.opacity = isActive ? "1" : "0";
          slide.style.pointerEvents = isActive ? "auto" : "none";
        });
        dots.forEach((dot, i) => {
          dot.style.backgroundColor = i === current ? "#FBDF00" : "rgba(255,255,255,0.4)";
        });
        syncYoutubeEmbeds();
      };

      const scheduleAdvance = () => {
        if (advanceTimer !== undefined) {
          clearTimeout(advanceTimer);
        }
        const el = slideEls[current];
        const raw = el?.dataset.duration;
        const ms = raw ? parseInt(raw, 10) : 10000;
        const duration = Number.isFinite(ms) && ms > 0 ? ms : 10000;
        advanceTimer = setTimeout(() => {
          const next = (current + 1) % total;
          setActive(next);
          scheduleAdvance();
        }, duration);
      };

      if (total > 0) {
        dots.forEach((dot, i) => {
          dot.addEventListener("click", () => {
            setActive(i);
            scheduleAdvance();
          });
        });

        setActive(0);
        scheduleAdvance();
      }
    }
  }
</script>
