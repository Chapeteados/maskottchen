---
const {
  href,
  label,
  className = "",
} = Astro.props as {
  href: string;
  label: string;
  className?: string;
};
---

<a
  href={href}
  class={`inline-flex items-center justify-center rounded-md md:rounded-lg bg-[#FBDF00] px-8 py-2 text-sm md:text-base font-semibold text-black shadow-md hover:shadow-lg hover:bg-yellow-300 transition ${className}`}
>
  {label}
</a>
