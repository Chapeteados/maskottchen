---
import NavLinks from "./NavLinks.astro";

const facebookUrl = import.meta.env.PUBLIC_FB_URL ?? "";
const instagramUrl = import.meta.env.PUBLIC_IG_URL ?? "";
---

<div
  class="h-full w-full bg-cover bg-center flex items-center justify-start py-8"
  style={`background-image: url('/footer.webp');`}
>
  <div class="mx-auto px-4 flex items-center justify-center gap-16">
    <img src="/footer_logo.webp" alt="Maskottchen Logo" class="w-20 h-20" />
    <div class="flex flex-col items-center gap-8">
      <ul class="flex items-center gap-4">
        <NavLinks itemClass="text-white" />
      </ul>
      <div class="flex items-center gap-16">
        <ul class="flex items-center gap-4">
          <li><a href="/" class="text-white">Terminos y Condiciones</a></li>
          <li><a href="/" class="text-white">Aviso de Privacidad</a></li>
        </ul>
        <ul class="flex items-center gap-4">
          <li>
            <a
              href={facebookUrl || "#"}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex text-white hover:opacity-80 transition"
              aria-label="Facebook"
            >
              <img
                src="/icons/facebook.svg"
                alt=""
                width="28"
                height="28"
                class="w-7 h-7 object-contain brightness-0 invert"
              />
            </a>
          </li>
          <li>
            <a
              href={instagramUrl || "#"}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex text-white hover:opacity-80 transition"
              aria-label="Instagram"
            >
              <img
                src="/icons/instagram.svg"
                alt=""
                width="28"
                height="28"
                class="w-7 h-7 object-contain brightness-0 invert"
              />
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</div>
