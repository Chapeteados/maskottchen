---
import LegalLinks from "./LegalLinks.astro";
import NavLinks from "./NavLinks.astro";
import SocialLinks from "./SocialLinks.astro";
---

<footer
  class="w-full bg-cover bg-center bg-no-repeat py-8 md:py-10"
  style={`background-image: url('/footer.webp');`}
>
  <div
    class="mx-auto flex w-full max-w-6xl flex-col items-center gap-8 px-4 sm:px-6 md:flex-row md:items-center md:justify-center md:gap-10 lg:gap-16"
  >
    <img
      src="/footer_logo.webp"
      alt="Maskottchen Logo"
      class="h-16 w-16 shrink-0 md:h-20 md:w-20"
      width="80"
      height="80"
    />

    <div
      class="flex w-full min-w-0 flex-col items-center gap-6 text-center md:w-auto md:items-start md:gap-8 md:text-left"
    >
      <nav aria-label="Pie de página" class="w-full md:w-auto">
        <ul class="flex flex-wrap justify-center gap-x-4 gap-y-2 md:justify-start md:gap-x-5">
          <NavLinks itemClass="text-white text-sm sm:text-base" activeClass="font-extrabold" />
        </ul>
      </nav>

      <div
        class="flex w-full flex-col items-center gap-6 sm:flex-row sm:flex-wrap sm:justify-center sm:gap-x-8 md:w-auto md:flex-nowrap md:items-center md:justify-start md:gap-12 lg:gap-16"
      >
        <ul
          class="flex flex-col items-center gap-2 text-center sm:flex-row sm:flex-wrap sm:justify-center sm:gap-x-6 sm:gap-y-1 md:justify-start md:gap-x-8 md:text-left"
        >
          <LegalLinks />
        </ul>

        <ul class="flex shrink-0 items-center justify-center gap-4 sm:gap-5 md:justify-start">
          <SocialLinks />
        </ul>
      </div>
    </div>
  </div>
</footer>
